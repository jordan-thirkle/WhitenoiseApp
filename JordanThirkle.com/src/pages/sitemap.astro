---
import MainLayout from '@/layouts/MainLayout.astro';
import { getCollection } from 'astro:content';

const title = "Sitemap";
const description = "HTML Sitemap for the Creator Hub.";

const blogPosts = await getCollection('blog');
const projects = await getCollection('projects');
const devlogs = await getCollection('devlog');

const sortedBlogPosts = blogPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const sortedProjects = projects.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const sortedDevlogs = devlogs.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<MainLayout title={title} description={description}>
  <div class="max-w-3xl mx-auto space-y-12">
    <header class="mb-16">
      <h1 class="text-4xl md:text-6xl font-bold tracking-tight text-white mb-6">
        Sitemap
      </h1>
      <p class="text-xl text-zinc-400">
        A complete index of the site's architecture.
      </p>
    </header>

    <div class="space-y-16">

      <section>
        <h2 class="text-2xl font-bold text-white mb-6 border-b border-zinc-800 pb-2">Core Pages</h2>
        <ul class="space-y-3 pl-4 list-disc list-inside text-zinc-400">
          <li><a href="/" class="hover:text-white transition-colors">Home</a></li>
          <li><a href="/about" class="hover:text-white transition-colors">The Story</a></li>
          <li><a href="/uses" class="hover:text-white transition-colors">Uses</a></li>
          <li><a href="/contact" class="hover:text-white transition-colors">Contact</a></li>
          <li><a href="/privacy" class="hover:text-white transition-colors">Privacy Policy</a></li>
          <li><a href="/terms" class="hover:text-white transition-colors">Terms of Service</a></li>
          <li><a href="/rss.xml" class="hover:text-white transition-colors" target="_blank" rel="noopener noreferrer">RSS Feed</a></li>
        </ul>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-white mb-6 border-b border-zinc-800 pb-2">
          <a href="/projects" class="hover:text-white transition-colors">Projects</a>
        </h2>
        <ul class="space-y-3 pl-4 list-disc list-inside text-zinc-400">
          {sortedProjects.map(project => (
            <li>
              <a href={`/projects/${project.id}`} class="hover:text-white transition-colors">
                {project.data.title}
              </a>
            </li>
          ))}
        </ul>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-white mb-6 border-b border-zinc-800 pb-2">
          <a href="/blog" class="hover:text-white transition-colors">Blog</a>
        </h2>
        <ul class="space-y-3 pl-4 list-disc list-inside text-zinc-400">
          {sortedBlogPosts.map(post => (
            <li>
              <a href={`/blog/${post.id}`} class="hover:text-white transition-colors">
                {post.data.title}
              </a>
            </li>
          ))}
        </ul>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-white mb-6 border-b border-zinc-800 pb-2">
          <a href="/devlog" class="hover:text-white transition-colors">Devlog</a>
        </h2>
        <ul class="space-y-3 pl-4 list-disc list-inside text-zinc-400">
          {sortedDevlogs.map(log => (
            <li>
              <a href={`/devlog/${log.id}`} class="hover:text-white transition-colors">
                {log.data.title}
              </a>
            </li>
          ))}
        </ul>
      </section>

    </div>
  </div>
</MainLayout>
