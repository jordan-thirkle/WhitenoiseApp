---
import { getCollection } from 'astro:content';
import MainLayout from '@/layouts/MainLayout.astro';

import { ProjectFilters } from '@/components/react/ProjectFilters';

const projects = (await getCollection('projects')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const categories = [...new Set(projects.map(p => p.data.category))];

const title = "Projects | Jordan Thirkle";
const description = "A collection of my recent SaaS, Games, and Open Source projects.";
---

<MainLayout title={title} description={description}>
  <section class="max-w-5xl mx-auto py-12">
    <header class="text-center mb-20">
      <h1 class="text-5xl md:text-7xl font-bold tracking-tight text-white mb-8">
        Building at the <span class="bg-gradient-to-r from-zinc-50 to-zinc-400 bg-clip-text text-transparent">speed of AI.</span>
      </h1>
      <p class="text-lg text-zinc-400 max-w-2xl mx-auto leading-relaxed">
        A curated selection of high-performance SaaS platforms, bio-horror games, and minimalist architectural frameworks.
      </p>
    </header>

    <ProjectFilters client:load categories={categories} />

    <div id="project-grid" class="grid grid-cols-1 md:grid-cols-2 gap-10">
      {projects.map((project) => (
        <article 
          class="group relative flex flex-col bg-zinc-900 border border-zinc-800 rounded-3xl overflow-hidden hover:border-zinc-700 transition-all hover:shadow-2xl project-card"
          data-category={project.data.category.toLowerCase()}
        >
          <div class="aspect-video overflow-hidden border-b border-zinc-800">
            <img 
              src={project.data.image} 
              alt={project.data.title}
              class="w-full h-full object-cover opacity-60 group-hover:opacity-100 group-hover:scale-105 transition-all duration-700"
            />
          </div>
          
          <div class="p-8 flex flex-col flex-grow">
            <div class="flex items-center justify-between mb-6">
              <span class="text-[10px] font-bold uppercase tracking-[0.2em] text-zinc-500">{project.data.category}</span>
              <span class="text-[10px] font-bold uppercase tracking-[0.2em] text-zinc-500">{project.data.timeline || 'Continuous'}</span>
            </div>

            <h2 class="text-2xl font-bold text-white mb-4 group-hover:text-zinc-200 transition-colors">
              <a href={`/projects/${project.id}`}>
                <span class="absolute inset-0 z-10" />
                {project.data.title}
              </a>
            </h2>

            <p class="text-zinc-400 text-sm leading-relaxed mb-8 line-clamp-2">
              {project.data.description}
            </p>

            <div class="mt-auto flex flex-wrap gap-2 relative z-20">
              {project.data.tech.map((tech) => (
                <span class="text-[9px] font-bold uppercase tracking-tight text-zinc-400 bg-zinc-950 px-2 py-0.5 rounded border border-zinc-800">
                  {tech}
                </span>
              ))}
            </div>
          </div>
        </article>
      ))}
    </div>

    <!-- Project Timeline View -->
    <div id="project-timeline" class="hidden space-y-12 max-w-3xl mx-auto border-l border-zinc-900 ml-4 md:ml-auto">
      {projects.map((project) => (
        <article 
          class="relative pl-12 group project-timeline-item"
          data-category={project.data.category.toLowerCase()}
        >
          <div class="absolute left-[-5px] top-2 w-2.5 h-2.5 rounded-full bg-zinc-800 border-2 border-zinc-950 group-hover:bg-white group-hover:scale-125 transition-all"></div>
          <div class="flex flex-col md:flex-row md:items-baseline gap-2 md:gap-8 mb-2">
            <time class="text-[10px] font-bold uppercase tracking-widest text-zinc-500 shrink-0">
               {project.data.pubDate.toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}
            </time>
            <h2 class="text-xl font-bold text-white group-hover:text-zinc-200 transition-colors">
              <a href={`/projects/${project.id}`}>{project.data.title}</a>
            </h2>
            <span class="text-[10px] font-bold uppercase tracking-widest text-zinc-600">{project.data.category}</span>
          </div>
          <p class="text-sm text-zinc-500 line-clamp-2 max-w-2xl">{project.data.description}</p>
        </article>
      ))}
    </div>
  </section>

  <script>
    import { activeProjectFilter, activeProjectsView } from '@/store/projects';
    import { applyCategoryFilter } from '@/utils/dom';

    const grid = document.getElementById('project-grid');
    const timeline = document.getElementById('project-timeline');
    const cards = document.querySelectorAll('.project-card');
    const timelineItems = document.querySelectorAll('.project-timeline-item');

    // Handle Category Filtering
    activeProjectFilter.subscribe((filter) => {
      applyCategoryFilter(cards, filter);
      applyCategoryFilter(timelineItems, filter);
    });

    // Handle View Switching
    activeProjectsView.subscribe((view) => {
      if (view === 'grid') {
        grid?.classList.remove('hidden');
        grid?.classList.add('grid');
        timeline?.classList.add('hidden');
      } else {
        grid?.classList.add('hidden');
        grid?.classList.remove('grid');
        timeline?.classList.remove('hidden');
      }
    });

    // Handle popstate for back/forward navigation
    window.addEventListener('popstate', () => {
      const params = new URLSearchParams(window.location.search);
      activeProjectFilter.set(params.get('filter'));
      activeProjectsView.set((params.get('view') as any) || 'grid');
    });
  </script>
</MainLayout>
