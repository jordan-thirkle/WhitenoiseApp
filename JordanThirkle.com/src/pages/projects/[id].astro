---
import { getCollection, render } from 'astro:content';
import MainLayout from '@/layouts/MainLayout.astro';
import { EngagementDock } from '@/components/react/EngagementDock';
import { Giscus } from '@/components/react/Giscus';
import { Image } from 'astro:assets';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(project => ({
    params: { id: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<MainLayout title={project.data.title} description={project.data.description} image={`/og/projects/${project.id}.png`}>
  <article class="space-y-16">
    <header class="max-w-4xl mx-auto">
      <a href="/projects" class="text-sm font-bold text-zinc-500 hover:text-white transition-colors mb-12 inline-block uppercase tracking-widest">
        ← Back to projects
      </a>

      <div class="space-y-8 text-center mb-16">
        <h1 class="text-4xl md:text-7xl font-bold tracking-tighter text-white leading-[1.1]">
          {project.data.title}
        </h1>
        <p class="text-xl text-zinc-400 max-w-2xl mx-auto leading-relaxed">
          {project.data.description}
        </p>
      </div>

      <!-- Quick Info Bar -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 p-8 bg-zinc-900/50 border border-zinc-800 rounded-[2rem] mb-16">
        <div class="space-y-2">
          <p class="text-[9px] font-bold uppercase tracking-widest text-zinc-500">Tech Stack</p>
          <p class="text-sm font-medium text-zinc-300">{project.data.tech.join(', ')}</p>
        </div>
        <div class="space-y-2">
          <p class="text-[9px] font-bold uppercase tracking-widest text-zinc-500">Timeline</p>
          <p class="text-sm font-medium text-zinc-300">{project.data.timeline || 'Continuous'}</p>
        </div>
        <div class="space-y-2">
          <p class="text-[9px] font-bold uppercase tracking-widest text-zinc-500">Category</p>
          <p class="text-sm font-medium text-zinc-300">{project.data.category}</p>
        </div>
        <div class="space-y-2">
          <p class="text-[9px] font-bold uppercase tracking-widest text-zinc-500">Links</p>
          <div class="flex gap-4">
            {project.data.liveUrl && <a href={project.data.liveUrl} class="text-zinc-400 hover:text-white transition-colors" title="Live Demo" target="_blank" rel="noopener noreferrer"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg></a>}
            {project.data.githubUrl && <a href={project.data.githubUrl} class="text-zinc-400 hover:text-white transition-colors" title="GitHub Source" target="_blank" rel="noopener noreferrer"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg></a>}
          </div>
        </div>
      </div>

      <div class="aspect-[21/9] w-full overflow-hidden rounded-[2.5rem] border border-zinc-800 bg-zinc-900 shadow-2xl">
        <Image 
          src={project.data.image} 
          alt={project.data.title}
          width={1920}
          height={1080}
          loading="eager"
          fetchpriority="high"
          class="w-full h-full object-cover object-center transition-transform duration-700 hover:scale-105"
        />
      </div>
    </header>

    {project.data.mission && (
      <section class="p-8 bg-zinc-900 border border-zinc-800 rounded-3xl relative overflow-hidden">
        <div class="relative z-10">
          <h2 class="text-lg font-bold text-white mb-4 uppercase tracking-widest text-zinc-400 flex items-center gap-2">
            <span class="w-2 h-2 rounded-full bg-emerald-500"></span>
            The Mission
          </h2>
          <p class="text-xl md:text-2xl font-medium text-zinc-200 leading-snug">
            "{project.data.mission}"
          </p>
        </div>
      </section>
    )}

    <div class="prose prose-invert prose-zinc max-w-3xl mx-auto prose-headings:font-bold prose-a:text-white hover:prose-a:text-zinc-300 transition-colors prose-img:rounded-3xl">
      <Content />
    </div>

    <!-- Giscus Comments Section -->
    <div id="comments" class="mt-24 pt-12 border-t border-zinc-900 not-prose">
      <div class="mb-8">
        <h2 class="text-2xl font-bold text-white">Project Discussion</h2>
        <p class="text-zinc-400 mt-2">Questions about the architecture or implementation? Drop a comment below.</p>
      </div>
      <Giscus client:visible />
    </div>
  </article>

  <EngagementDock client:load title={project.data.title} url={Astro.url.toString()} path={Astro.url.pathname} initialLikes={project.data.likes} initialViews={project.data.views} />
</MainLayout>
