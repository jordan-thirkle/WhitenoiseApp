---
import MainLayout from '@/layouts/MainLayout.astro';
import { getCollection } from 'astro:content';
import ProjectCard from '@/components/astro/ProjectCard.astro';


const featuredProjects = await getCollection('projects', ({ data }) => {
  return data.featured === true;
});

const latestPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const latestLogs = (await getCollection('devlog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<MainLayout 
  title="Engineering at the speed of AI" 
  description="Computer Science graduate and full-stack architect crafting high-performance web, app, and game ecosystems using Astro, React, and AI-accelerated workflows."
>
  <!-- Hero Section -->
  <section class="mb-24 mt-12 flex flex-col items-center text-center">
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-zinc-900 border border-zinc-800 text-[10px] font-bold uppercase tracking-widest text-zinc-400 mb-8 animate-pulse">
      <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 shadow-[0_0_8px_rgba(16,185,129,0.6)]"></span>
      working on this website
    </div>
    <h1 class="text-5xl md:text-8xl font-bold tracking-tighter text-white mb-6 leading-none max-w-4xl">
      Engineering at the <span class="bg-gradient-to-r from-zinc-50 to-zinc-400 bg-clip-text text-transparent">speed of AI.</span>
    </h1>
    <p class="text-xl text-zinc-400 max-w-2xl leading-relaxed">
      Computer Science graduate and full-stack architect. I craft high-performance web, app, and game ecosystems using Astro, React, and AI-accelerated workflows.
    </p>
    
    <div class="mt-10 flex flex-wrap gap-4 justify-center">
      <a href="/projects" class="px-8 py-3 bg-white text-zinc-950 font-bold rounded-full hover:bg-zinc-200 transition-colors shadow-lg">
        View Portfolio
      </a>
      <a href="/blog" class="px-8 py-3 bg-transparent text-white font-bold border border-zinc-800 rounded-full hover:border-zinc-700 transition-colors">
        Read the Guides
      </a>
    </div>
  </section>

  <!-- Projects Grid -->
  <section class="mb-24">
    <div class="flex items-end justify-between mb-12">
      <div>
        <h2 class="text-3xl font-bold text-white tracking-tight">Featured Work</h2>
        <p class="text-zinc-400 mt-2">A selection of my recent SaaS and open-source projects.</p>
      </div>
      <a href="/projects" class="px-6 py-2 bg-zinc-900 text-zinc-300 font-semibold border border-zinc-800 rounded-full hover:border-zinc-700 hover:text-white transition-all text-sm">
        View All Projects
      </a>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {featuredProjects.map((project, index) => (
        <ProjectCard project={project} eager={index < 2} />
      ))}
    </div>
  </section>

  <!-- Dev Log Section -->
  <section class="mb-24">
    <div class="flex items-end justify-between mb-12">
      <div>
        <h2 class="text-3xl font-bold text-white tracking-tight">Recent Activity</h2>
        <p class="text-zinc-400 mt-2">Raw updates from the daily build.</p>
      </div>
      <a href="/devlog" class="text-sm font-semibold text-zinc-400 hover:text-white transition-colors">
        Full Log →
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {latestLogs.map((log) => (
        <a href={`/devlog/${log.id}`} class="group p-6 bg-zinc-900/50 border border-zinc-800 rounded-2xl hover:border-zinc-700 transition-all">
          <time class="text-[10px] font-bold uppercase tracking-widest text-zinc-600 mb-3 block">{new Date(log.data.pubDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}</time>
          <h3 class="text-lg font-bold text-zinc-300 group-hover:text-white transition-colors line-clamp-2">
            {log.data.title}
          </h3>
        </a>
      ))}
    </div>
  </section>

  <!-- Blog List -->
  <section>
    <div class="flex items-end justify-between mb-12">
      <div>
        <h2 class="text-3xl font-bold text-white tracking-tight">Latest Writing</h2>
        <p class="text-zinc-400 mt-2">Deep dives into software architecture and minimalism.</p>
      </div>
      <a href="/blog" class="text-sm font-semibold text-zinc-400 hover:text-white transition-colors">
        Read Archive →
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {latestPosts.map((post) => (
        <a href={`/blog/${post.id}`} class="group relative flex flex-col bg-zinc-900 border border-zinc-800 rounded-2xl overflow-hidden hover:border-zinc-700 transition-all">
          {post.data.image && (
            <div class="aspect-video overflow-hidden">
              <img 
                src={post.data.image} 
                alt={post.data.title}
                class="w-full h-full object-cover opacity-60 group-hover:opacity-100 group-hover:scale-105 transition-all duration-500"
              />
            </div>
          )}
          <div class="p-5 flex flex-col flex-grow">
            <time class="text-[9px] font-bold uppercase tracking-widest text-zinc-500 mb-2 block">
              {new Date(post.data.pubDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
            </time>
            <h3 class="text-base font-bold text-zinc-200 group-hover:text-white transition-colors line-clamp-2 leading-snug">
              {post.data.title}
            </h3>
          </div>
        </a>
      ))}
    </div>
  </section>
</MainLayout>
