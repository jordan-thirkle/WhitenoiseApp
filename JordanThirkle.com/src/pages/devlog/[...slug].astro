---
import { getCollection, render } from 'astro:content';
import MainLayout from '@/layouts/MainLayout.astro';
import { formatDate } from '@/utils/index';
import { Giscus } from '@/components/react/Giscus';
import { EngagementDock } from '@/components/react/EngagementDock';

export async function getStaticPaths() {
  const logs = await getCollection('devlog');
  return logs.map((log) => ({
    params: { slug: log.id },
    props: { log },
  }));
}

const { log } = Astro.props;
const { Content } = await render(log);

const title = `${log.data.title} | Jordan Thirkle Dev Log`;
---

<MainLayout title={title} description={log.data.title}>
  <div class="max-w-4xl mx-auto">
    <header class="mb-20">
      <a href="/devlog" class="text-[10px] font-bold text-zinc-500 hover:text-white transition-colors mb-12 inline-block uppercase tracking-[0.2em]">← Back to Logs</a>
      
      <div class="space-y-8">
        <h1 class="text-4xl md:text-7xl font-bold tracking-tighter text-white leading-tight">
          {log.data.title}
        </h1>

        <div class="flex flex-wrap items-center gap-6 py-6 border-y border-zinc-900">
          <div class="flex flex-col gap-1">
            <span class="text-[9px] font-bold text-zinc-500 uppercase tracking-widest">Entry Date</span>
            <span class="text-sm font-medium text-zinc-300">{formatDate(log.data.pubDate)}</span>
          </div>
          
          <div class="w-px h-8 bg-zinc-900 hidden md:block"></div>
          
          <div class="flex flex-col gap-1">
            <span class="text-[9px] font-bold text-zinc-500 uppercase tracking-widest">Classification</span>
            <div class="flex gap-2">
              {log.data.tags.map(tag => (
                <span class="text-xs font-bold text-zinc-400">#{tag}</span>
              ))}
            </div>
          </div>

          <div class="w-px h-8 bg-zinc-900 hidden md:block"></div>

          <div class="flex flex-col gap-1">
            <span class="text-[9px] font-bold text-zinc-500 uppercase tracking-widest">Build Status</span>
            <span class="flex items-center gap-2 text-sm font-medium text-emerald-500">
              <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
              Stable
            </span>
          </div>
        </div>
      </div>
    </header>

    <div class="prose prose-zinc prose-invert max-w-3xl mx-auto text-zinc-300 leading-relaxed">
      <Content />
    </div>

    <!-- Giscus Comments Section -->
    <div id="comments" class="mt-24 pt-12 border-t border-zinc-900 not-prose">
      <div class="mb-8">
        <h2 class="text-2xl font-bold text-white">Log Discussion</h2>
        <p class="text-zinc-400 mt-2">Questions or thoughts on this update?</p>
      </div>
      <Giscus client:visible />
    </div>
  </div>

  <EngagementDock client:load title={log.data.title} url={Astro.url.toString()} />
</MainLayout>
