---
import { getCollection } from 'astro:content';
import MainLayout from '@/layouts/MainLayout.astro';


const logs = (await getCollection('devlog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const title = "Dev Log | Jordan Thirkle";
const description = "Raw, unfiltered updates from the build. Engineering in public, day by day.";
---

<MainLayout title={title} description={description}>
  <div class="max-w-4xl mx-auto py-12">
    <header class="text-center mb-24">
      <h1 class="text-4xl md:text-6xl font-bold tracking-tight text-white mb-8">
        Audit & <span class="bg-gradient-to-r from-zinc-50 to-zinc-400 bg-clip-text text-transparent">Iteration.</span>
      </h1>
      <p class="text-lg text-zinc-400 max-w-2xl mx-auto leading-relaxed">
        A technical audit trail of my shipping velocity. Raw updates, architectural pivots, and real-time engineering breakthroughs.
      </p>
    </header>

    <div class="relative">
      <!-- Central Vertical Line -->
      <div class="absolute left-4 md:left-1/2 top-0 bottom-0 w-px bg-zinc-900 md:-translate-x-px"></div>

      <div class="space-y-24">
        {logs.map((log, index) => (
          <div class="relative flex flex-col md:flex-row items-center group">
            <!-- Timeline Dot -->
            <div class="absolute left-4 md:left-1/2 w-3 h-3 rounded-full bg-zinc-800 border border-zinc-950 z-20 -translate-x-1.5 transition-transform group-hover:scale-125 group-hover:bg-white group-hover:shadow-[0_0_12px_rgba(255,255,255,0.4)]"></div>
            
            <div class={`w-full md:w-1/2 ${index % 2 === 0 ? 'md:pr-16 md:text-right order-2 md:order-1' : 'md:pl-16 md:text-left md:ml-auto order-2 md:order-2'} pl-12 pr-4`}>
              <time class="text-[10px] font-mono font-bold uppercase tracking-[0.2em] text-zinc-500 mb-3 block">
                {log.data.pubDate.toLocaleDateString('en-US', { 
                  year: 'numeric', 
                  month: 'short', 
                  day: 'numeric',
                  hour: '2-digit',
                  minute: '2-digit'
                })}
              </time>
              
              <a href={`/devlog/${log.id}`} class="group/link block">
                <h2 class="text-2xl font-bold text-zinc-100 mb-4 group-hover/link:text-white transition-colors">
                  {log.data.title}
                </h2>
                <p class="text-sm text-zinc-400 mb-6 line-clamp-3 leading-relaxed">
                  {log.data.description}
                </p>
              </a>

              <div class={`flex flex-wrap gap-2 mb-6 ${index % 2 === 0 ? 'md:justify-end' : 'md:justify-start'}`}>
                {log.data.tags.map(tag => (
                  <span class="text-[9px] font-bold text-zinc-500 bg-zinc-950 px-2 py-0.5 rounded border border-zinc-800 uppercase tracking-tight">
                    {tag}
                  </span>
                ))}
              </div>
              
              <div class={`flex items-center gap-4 text-[10px] font-bold text-zinc-600 ${index % 2 === 0 ? 'md:justify-end' : 'md:justify-start'}`}>
                <a href="https://x.com/jordan_thirkle" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors flex items-center gap-1.5 uppercase tracking-widest">
                  <svg viewBox="0 0 24 24" class="w-3 h-3 fill-current"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"></path></svg>
                  X.com
                </a>
                <span class="w-1 h-1 rounded-full bg-zinc-800"></span>
                <a href={`/devlog/${log.id}`} class="hover:text-white transition-colors uppercase tracking-widest">
                  Full Log
                </a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</MainLayout>
