---
import MainLayout from '@/layouts/MainLayout.astro';

const title = "Murmur: Sleep Sounds & Timer";
const description = "Murmur is a free ambient sound app for families. Rain, ocean, white noise, and more — playing all night with no interruptions.";
---

<MainLayout title={title} description={description}>
  <div class="max-w-3xl mx-auto space-y-16">

    <!-- Hero -->
    <header class="mb-16 text-center">
      <div class="inline-flex items-center gap-3 mb-8">
        <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-blue-500/20 to-blue-700/20 border border-blue-500/30 flex items-center justify-center text-3xl">
          🌧
        </div>
      </div>
      <h1 class="text-4xl md:text-6xl font-bold tracking-tight text-white mb-6">
        Murmur
      </h1>
      <p class="text-xl text-zinc-400 max-w-xl mx-auto">
        Ambient sleep sounds for families. Rain, ocean, white noise, and more — playing all night with no interruptions.
      </p>
      <p class="mt-4 text-sm text-zinc-500">
        Coming soon to Google Play. iOS to follow.
      </p>
      <div class="mt-8 flex gap-4 justify-center">
        <div class="inline-flex items-center gap-2 px-5 py-3 rounded-full bg-zinc-800 border border-zinc-700 text-zinc-400 text-sm cursor-not-allowed select-none">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M17.05 20.28c-.98.95-2.05.8-3.08.35-1.09-.46-2.09-.48-3.24 0-1.44.62-2.2.44-3.06-.35C2.79 15.25 3.51 7.7 9.05 7.37c1.33.07 2.24.82 3.01.82.82 0 2.37-1.01 3.99-.86 1.68.13 3.26.79 4.42 2.2-3.87 2.31-3.24 7.35.58 9.75zM12.03 7.25c-.15-2.23 1.66-4.07 3.74-4.25.29 2.58-2.34 4.5-3.74 4.25z"/></svg>
          App Store — Coming Soon
        </div>
        <div class="inline-flex items-center gap-2 px-5 py-3 rounded-full bg-zinc-800 border border-zinc-700 text-zinc-400 text-sm cursor-not-allowed select-none">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M3.18 23.76c.3.17.63.24.96.24.37 0 .73-.1 1.06-.3l13.04-7.52-2.96-2.96-12.1 10.54zM.48 1.1C.18 1.42 0 1.9 0 2.52v18.96c0 .62.18 1.1.48 1.42l.08.08 10.62-10.62v-.25L.56 1.02.48 1.1zM21.16 10.3l-2.86-1.65-3.3 3.3 3.3 3.3 2.89-1.67c.82-.47.82-1.25-.03-1.28z M4.2.54L17.24 8.06l-2.96 2.96L4.2.54z"/></svg>
          Google Play — Coming Soon
        </div>
      </div>
    </header>
    
    <!-- Live Demo -->
    <section class="mb-16">
      <div class="p-1 rounded-3xl bg-gradient-to-br from-zinc-800 to-zinc-900 border border-zinc-700 shadow-2xl overflow-hidden aspect-video md:aspect-[16/9]">
        <iframe 
          src="https://murmur.vercel.app" 
          class="w-full h-full rounded-2xl" 
          title="Murmur Live Demo"
          allow="autoplay"
        ></iframe>
      </div>
      <p class="text-center text-xs text-zinc-500 mt-4">
        Interactive Web Demo (Desktop Chrome/Safari Recommended)
      </p>
    </section>

    <!-- Features -->
    <section>
      <h2 class="text-2xl font-bold text-white mb-8">Why Murmur?</h2>
      <div class="grid md:grid-cols-3 gap-6">
        <div class="p-6 rounded-2xl bg-zinc-900 border border-zinc-800">
          <div class="text-2xl mb-3">🌙</div>
          <h3 class="text-white font-semibold mb-2">Plays all night</h3>
          <p class="text-zinc-400 text-sm">No "Are you still watching?" No timeouts. Audio keeps playing after your screen locks.</p>
        </div>
        <div class="p-6 rounded-2xl bg-zinc-900 border border-zinc-800">
          <div class="text-2xl mb-3">⏱</div>
          <h3 class="text-white font-semibold mb-2">Sleep timer</h3>
          <p class="text-zinc-400 text-sm">Set it and forget it. Murmur fades out gently and stops — no jarring silence at 3am.</p>
        </div>
        <div class="p-6 rounded-2xl bg-zinc-900 border border-zinc-800">
          <div class="text-2xl mb-3">🔒</div>
          <h3 class="text-white font-semibold mb-2">Zero data collected</h3>
          <p class="text-zinc-400 text-sm">No accounts. No analytics. No tracking. Just sound. Safe for children and parents alike.</p>
        </div>
      </div>
    </section>

    <!-- Sound library preview -->
    <section>
      <h2 class="text-2xl font-bold text-white mb-8">Sound library</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
        {[
          { icon: "🌧", name: "Rain" },
          { icon: "⛈", name: "Thunderstorm" },
          { icon: "🌊", name: "Ocean" },
          { icon: "🌲", name: "Forest" },
          { icon: "💨", name: "Fan" },
          { icon: "🟫", name: "Brown Noise" },
          { icon: "🌸", name: "Pink Noise" },
          { icon: "⬜", name: "White Noise" },
        ].map(sound => (
          <div class="p-4 rounded-xl bg-zinc-900 border border-zinc-800 flex flex-col items-center gap-2">
            <span class="text-2xl">{sound.icon}</span>
            <span class="text-zinc-300 text-sm font-medium">{sound.name}</span>
          </div>
        ))}
      </div>
    </section>

    <!-- Legal links -->
    <section class="pt-8 border-t border-zinc-800">
      <h2 class="text-2xl font-bold text-white mb-4">Legal</h2>
      <div class="flex gap-6 text-sm">
        <a href="/murmur/privacy" class="text-blue-400 hover:text-blue-300 transition-colors">Privacy Policy</a>
        <a href="/murmur/terms" class="text-blue-400 hover:text-blue-300 transition-colors">Terms of Service</a>
        <a href="mailto:jordan@jordanthirkle.com" class="text-blue-400 hover:text-blue-300 transition-colors">Support</a>
      </div>
    </section>

  </div>
</MainLayout>
