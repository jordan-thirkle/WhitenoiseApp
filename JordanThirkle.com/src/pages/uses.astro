---
import MainLayout from '@/layouts/MainLayout.astro';
import { EngagementDock } from '@/components/react/EngagementDock';

const title = "Uses";
const description = "A curated list of the gear, software, and AI technologies I use daily.";

interface EquipmentItem {
  name: string;
  description: string;
  href: string;
}

interface EquipmentCategory {
  category: string;
  items: EquipmentItem[];
}

const equipment: EquipmentCategory[] = [
  {
    category: "Hardware",
    items: [
      { name: "MacBook M4 Air 15\"", description: "The ultimate portable workhorse for engineering on the go.", href: "https://www.apple.com/macbook-air/" },
      { name: "Pro Display XDR", description: "Reference-grade color accuracy for high-fidelity design work.", href: "https://www.apple.com/pro-display-xdr/" },
      { name: "Keychron Q1 Pro", description: "Satisfying tactile feedback with a minimalist aesthetic.", href: "https://www.keychron.com/products/keychron-q1-pro-qmk-via-wireless-custom-mechanical-keyboard" },
    ]
  },
  {
    category: "Software & AI",
    items: [
      { name: "Antigravity", description: "My primary AI coding partner for complex architectural tasks.", href: "#" },
      { name: "Gemini AI", description: "Deepmind's most capable model for reasoning and logic.", href: "https://gemini.google.com/" },
      { name: "Claude AI", description: "Sophisticated language modeling and technical writing.", href: "https://claude.ai/" },
      { name: "VS Code", description: "Minimalist environment with a focus on speed and clarity.", href: "https://code.visualstudio.com/" },
      { name: "Arc Browser", description: "A focused web experience that stays out of the way.", href: "https://arc.net/" },
      { name: "Warp", description: "Modern terminal with AI integration and collaborative tools.", href: "https://www.warp.dev/" },
    ]
  }
];
---

<MainLayout title={title} description={description}>
  <section class="max-w-5xl mx-auto py-12">
    <header class="text-center mb-24">
      <h1 class="text-4xl md:text-6xl font-bold tracking-tight text-white mb-8">
        Gear & <span class="bg-gradient-to-r from-zinc-50 to-zinc-400 bg-clip-text text-transparent">Infrastructure.</span>
      </h1>
      <p class="text-lg text-zinc-400 max-w-2xl mx-auto leading-relaxed">
        A curated list of the hardware, software, and AI-native technologies I use to build digital products at the highest level.
      </p>
    </header>

    <div class="space-y-32">
      {equipment.map((group) => (
        <section class="space-y-12">
          <div class="flex items-center gap-6">
            <h2 class="text-[10px] font-bold uppercase tracking-[0.3em] text-zinc-500 whitespace-nowrap">
              {group.category}
            </h2>
            <div class="h-px w-full bg-zinc-900"></div>
          </div>
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {group.items.map((item) => (
              <a 
                href={item.href}
                target="_blank"
                rel="noopener noreferrer"
                class="group p-8 bg-zinc-900/50 border border-zinc-800 rounded-[2rem] hover:border-zinc-700 transition-all hover:shadow-2xl"
              >
                <div class="flex flex-col gap-4">
                  <div class="flex items-center justify-between">
                    <h3 class="text-xl font-bold text-white group-hover:text-zinc-200 transition-colors">
                      {item.name}
                    </h3>
                    <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-zinc-600 group-hover:text-zinc-300 transition-colors">
                      <path d="M7 7h10v10"/><path d="M7 17 17 7"/>
                    </svg>
                  </div>
                  <p class="text-sm text-zinc-400 leading-relaxed group-hover:text-zinc-300 transition-colors">
                    {item.description}
                  </p>
                </div>
              </a>
            ))}
          </div>
        </section>
      ))}
    </div>

    <EngagementDock
      client:load
      title={title}
      url={Astro.url.toString()}
      path={Astro.url.pathname}
      showComments={false}
    />
  </section>
</MainLayout>
