---
import MainLayout from '@/layouts/MainLayout.astro';
---

<MainLayout title="404: Page Not Found" description="The page you are looking for doesn't exist.">
  <div class="flex flex-col items-center justify-center min-h-[60vh] text-center px-6">
    <div class="relative mb-12">
      <h1 class="text-[12rem] md:text-[16rem] font-bold text-white tracking-tighter opacity-[0.03] select-none leading-none">404</h1>
      <div class="absolute inset-0 flex flex-col items-center justify-center space-y-4">
        <h2 class="text-4xl md:text-5xl font-bold text-white tracking-tight">Lost in the void.</h2>
        <p class="text-zinc-400 max-w-md mx-auto leading-relaxed">
          The page you are looking for has been moved to a new dimension or never existed in this one.
        </p>
      </div>
    </div>
    
    <a href="/" class="group relative px-10 py-4 bg-white text-zinc-950 font-bold rounded-full overflow-hidden transition-all hover:scale-105 active:scale-95 shadow-2xl">
      <span class="relative z-10">Return to Reality</span>
      <div class="absolute inset-0 bg-gradient-to-r from-zinc-200 to-white opacity-0 group-hover:opacity-100 transition-opacity"></div>
    </a>
  </div>
</MainLayout>
