---
import MainLayout from '@/layouts/MainLayout.astro';
import { CopyEmail } from '@/components/react/CopyEmail';
---

<MainLayout 
  title="Get in touch" 
  description="I'm always open to discussing new projects, open-source collaborations, or consulting opportunities."
>
  <div class="relative py-12 space-y-24">
    <!-- Subtle Background Glow -->
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-3xl h-full opacity-20 pointer-events-none">
      <div class="absolute top-0 left-0 w-full h-full bg-[radial-gradient(circle_at_50%_0%,rgba(63,63,70,0.4)_0%,transparent_70%)]"></div>
    </div>

    <header class="text-center mb-20 relative z-10">
      <div class="inline-flex items-center gap-2 px-3 py-1 bg-emerald-500/10 border border-emerald-500/20 rounded-full mb-8">
        <span class="w-1.5 h-1.5 bg-emerald-500 rounded-full animate-pulse"></span>
        <span class="text-[10px] font-bold uppercase tracking-widest text-emerald-500">Available for Q2 2026</span>
      </div>
      <h1 class="text-5xl md:text-7xl font-bold tracking-tight text-white mb-8">
        Get in <span class="bg-gradient-to-r from-zinc-50 to-zinc-400 bg-clip-text text-transparent">touch.</span>
      </h1>
      <p class="text-lg text-zinc-400 max-w-2xl mx-auto leading-relaxed">
        I'm currently specialized in high-performance ecosystem design and minimalist product architecture. Let's build something exceptional.
      </p>
    </header>

    <div class="max-w-4xl mx-auto space-y-24 relative z-10">
      <section class="space-y-12 flex flex-col items-center">
        <div class="flex flex-col items-center gap-2">
          <h2 class="text-[10px] font-bold uppercase tracking-[0.3em] text-zinc-600">Primary Channel</h2>
          <div class="w-12 h-px bg-zinc-900"></div>
        </div>
        <CopyEmail client:load />
      </section>

      <section class="space-y-16">
        <div class="flex flex-col items-center gap-2 mb-4">
          <h2 class="text-[10px] font-bold uppercase tracking-[0.3em] text-zinc-600">Digital Footprint</h2>
          <div class="w-12 h-px bg-zinc-900"></div>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <a 
            href="https://x.com/jordan_thirkle"
            target="_blank"
            rel="noopener noreferrer"
            class="group flex flex-col p-8 bg-zinc-900 border border-zinc-800 rounded-3xl hover:border-zinc-700 hover:-translate-y-1 transition-all duration-300 gap-8"
          >
            <div class="flex items-center justify-between">
              <div class="w-12 h-12 bg-zinc-800 rounded-2xl flex items-center justify-center text-zinc-400 group-hover:text-white transition-colors">
                <svg viewBox="0 0 24 24" aria-hidden="true" class="w-6 h-6 fill-current"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"></path></svg>
              </div>
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-zinc-800 group-hover:text-zinc-500 transition-colors"><path d="M7 7h10v10"/><path d="M7 17 17 7"/></svg>
            </div>
            <div>
               <span class="block text-sm font-bold text-white mb-1">X (Twitter)</span>
              <span class="text-xs text-zinc-500 group-hover:text-zinc-400 transition-colors">@jordan_thirkle</span>
            </div>
          </a>

          <a 
            href="https://github.com/jordan-thirkle"
            target="_blank"
            rel="noopener noreferrer"
            class="group flex flex-col p-8 bg-zinc-900 border border-zinc-800 rounded-3xl hover:border-zinc-700 hover:-translate-y-1 transition-all duration-300 gap-8"
          >
            <div class="flex items-center justify-between">
              <div class="w-12 h-12 bg-zinc-800 rounded-2xl flex items-center justify-center text-zinc-400 group-hover:text-white transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
              </div>
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-zinc-800 group-hover:text-zinc-500 transition-colors"><path d="M7 7h10v10"/><path d="M7 17 17 7"/></svg>
            </div>
            <div>
              <span class="block text-sm font-bold text-white mb-1">GitHub</span>
              <span class="text-xs text-zinc-500 group-hover:text-zinc-400 transition-colors">jordan-thirkle</span>
            </div>
          </a>

          <a 
            href="https://linkedin.com/in/jordanthirkle"
            target="_blank"
            rel="noopener noreferrer"
            class="group flex flex-col p-8 bg-zinc-900 border border-zinc-800 rounded-3xl hover:border-zinc-700 hover:-translate-y-1 transition-all duration-300 gap-8"
          >
            <div class="flex items-center justify-between">
              <div class="w-12 h-12 bg-zinc-800 rounded-2xl flex items-center justify-center text-zinc-400 group-hover:text-white transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
              </div>
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-zinc-800 group-hover:text-zinc-500 transition-colors"><path d="M7 7h10v10"/><path d="M7 17 17 7"/></svg>
            </div>
            <div>
              <span class="block text-sm font-bold text-white mb-1">LinkedIn</span>
              <span class="text-xs text-zinc-500 group-hover:text-zinc-400 transition-colors">Jordan Thirkle</span>
            </div>
          </a>
        </div>
      </section>

      <section class="border-t border-zinc-900 flex flex-col items-center">
        <h2 class="text-[10px] font-bold uppercase tracking-[0.3em] text-zinc-600 mb-8">Authoritative Compliance</h2>
        <p class="text-sm text-zinc-500 leading-relaxed max-w-2xl text-center">
          In accordance with the **UK Digital Use and Authority Act (2026)**, this page serves as the 
          <strong class="text-zinc-400 font-bold">Formal Complaints Procedure</strong> and feedback loop for all data subjects and 
          automated agents. If you wish to request data deletion, raise a grievance regarding 
          algorithmic representation, or exercise your "Right to Rectification" under current 
          AI-governance frameworks, please use the primary channel above. 
        </p>
      </section>
    </div>
  </div>
</MainLayout>
