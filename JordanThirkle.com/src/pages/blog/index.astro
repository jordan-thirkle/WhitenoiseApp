---
import { getCollection } from 'astro:content';
import MainLayout from '@/layouts/MainLayout.astro';

import { BlogFilters } from '@/components/react/BlogFilters';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const categories = [...new Set(posts.map(post => post.data.category))].sort();

const title = "Blog | Jordan Thirkle";
const description = "Articles on minimalist architecture, AI tools, and full-stack development.";

const schema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": title,
  "description": description,
  "url": Astro.url.toString(),
  "hasPart": posts.map(post => ({
    "@type": "BlogPosting",
    "headline": post.data.title,
    "url": `${Astro.site}blog/${post.id}`,
    "datePublished": post.data.pubDate.toISOString()
  }))
};
---

<MainLayout title={title} description={description}>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(schema)} />
  <section class="max-w-5xl mx-auto py-12">
    <header class="text-center mb-20">
      <h1 class="text-5xl md:text-7xl font-bold tracking-tight text-white mb-8">
        The <span class="bg-gradient-to-r from-zinc-50 to-zinc-400 bg-clip-text text-transparent">Digital Archive.</span>
      </h1>
      <p class="text-lg text-zinc-400 max-w-2xl mx-auto leading-relaxed">
        Strategic insights into high-performance ecosystem design, AI-native workflows, and the future of minimalist architecture.
      </p>
    </header>

    <BlogFilters client:load categories={categories} />

    <div id="blog-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {posts.map((post) => (
        <article 
          class="group relative flex flex-col bg-zinc-900 border border-zinc-800 rounded-3xl overflow-hidden hover:border-zinc-700 transition-all hover:shadow-2xl blog-post-card"
          data-category={post.data.category.toLowerCase()}
          data-date={post.data.pubDate.toISOString()}
        >
          {post.data.image && (
            <div class="aspect-video overflow-hidden border-b border-zinc-800">
              <img 
                src={post.data.image} 
                alt={post.data.title}
                class="w-full h-full object-cover opacity-60 group-hover:opacity-100 group-hover:scale-105 transition-all duration-700"
              />
            </div>
          )}
          
          <div class="p-8 flex flex-col flex-grow">
            <div class="flex items-center gap-3 text-[10px] font-bold text-zinc-500 uppercase tracking-[0.2em] mb-6">
              <span class="text-zinc-300">{post.data.category}</span>
              <span>•</span>
              <time datetime={post.data.pubDate.toISOString()}>
                {post.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
              </time>
            </div>

            <h2 class="text-2xl font-bold text-white mb-4 group-hover:text-zinc-200 transition-colors line-clamp-2">
              <a href={`/blog/${post.id}`}>
                <span class="absolute inset-0 z-10" />
                {post.data.title}
              </a>
            </h2>

            <p class="text-sm text-zinc-400 line-clamp-3 mb-8 leading-relaxed flex-grow">
              {post.data.description}
            </p>

            <div class="flex items-center justify-between mt-auto pt-6 border-t border-zinc-900/50">
               <span class="text-[10px] font-bold uppercase tracking-widest text-zinc-500">{post.data.readTime}</span>
               <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-zinc-800 group-hover:text-zinc-500 group-hover:translate-x-1 transition-all"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </div>
          </div>
        </article>
      ))}
    </div>

    <!-- Timeline View Container (Empty by default) -->
    <div id="blog-timeline" class="hidden space-y-12 max-w-3xl mx-auto border-l border-zinc-900 ml-4 md:ml-auto">
      {posts.map((post) => (
        <article 
          class="relative pl-12 group blog-post-timeline"
          data-category={post.data.category.toLowerCase()}
        >
          <div class="absolute left-[-5px] top-2 w-2.5 h-2.5 rounded-full bg-zinc-800 border-2 border-zinc-950 group-hover:bg-white group-hover:scale-125 transition-all"></div>
          <div class="flex flex-col md:flex-row md:items-baseline gap-2 md:gap-8 mb-2">
            <time class="text-[10px] font-bold uppercase tracking-widest text-zinc-500 shrink-0">
               {post.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
            </time>
            <h2 class="text-xl font-bold text-white group-hover:text-zinc-200 transition-colors">
              <a href={`/blog/${post.id}`}>{post.data.title}</a>
            </h2>
          </div>
          <p class="text-sm text-zinc-500 line-clamp-2 max-w-2xl">{post.data.description}</p>
        </article>
      ))}
    </div>
  </section>

  <script>
    import { activeBlogTag, activeBlogView } from '@/store/blog';
    import { applyCategoryFilter } from '@/utils/dom';

    const grid = document.getElementById('blog-grid');
    const timeline = document.getElementById('blog-timeline');
    const cards = document.querySelectorAll('.blog-post-card');
    const timelineItems = document.querySelectorAll('.blog-post-timeline');

    // Handle Category Filtering
    activeBlogTag.subscribe((filter) => {
      applyCategoryFilter(cards, filter);
      applyCategoryFilter(timelineItems, filter);
    });

    // Handle View Switching
    activeBlogView.subscribe((view) => {
      if (view === 'grid') {
        grid?.classList.remove('hidden');
        grid?.classList.add('grid');
        timeline?.classList.add('hidden');
      } else {
        grid?.classList.add('hidden');
        grid?.classList.remove('grid');
        timeline?.classList.remove('hidden');
      }
    });

    // Sync with URL
    const params = new URLSearchParams(window.location.search);
    const view = params.get('view');
    const tag = params.get('tag');
    if (view === 'timeline') activeBlogView.set('timeline');
    if (tag) activeBlogTag.set(tag);

    // Handle popstate
    window.addEventListener('popstate', () => {
      const params = new URLSearchParams(window.location.search);
      activeBlogTag.set(params.get('tag'));
      activeBlogView.set((params.get('view') as any) || 'grid');
    });
  </script>
</MainLayout>
