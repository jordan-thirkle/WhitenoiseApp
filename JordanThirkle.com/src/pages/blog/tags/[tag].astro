---
import { getCollection } from 'astro:content';
import MainLayout from '@/layouts/MainLayout.astro';
import { formatDate } from '@/utils/index';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const uniqueTags = [...new Set(posts.flatMap((post) => post.data.tags))];

  return uniqueTags.map((tag) => {
    const filteredPosts = posts.filter((post) =>
      post.data.tags.includes(tag)
    ).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
    
    return {
      params: { tag: tag.toLowerCase() },
      props: { posts: filteredPosts, tagName: tag },
    };
  });
}

const { posts, tagName } = Astro.props;
const title = `Posts tagged with #${tagName} | Jordan Thirkle`;
---

<MainLayout title={title} description={`All blog posts tagged with #${tagName}`}>
  <div class="space-y-12">
    <header class="space-y-4 text-center mb-16">
      <a href="/blog" class="text-sm text-zinc-500 hover:text-white transition-colors mb-8 inline-block">← Back to Blog</a>
      <h1 class="text-4xl md:text-6xl font-bold text-white tracking-tight">
        Posts tagged with <span class="text-zinc-500">#{tagName}</span>
      </h1>
      <p class="text-zinc-400 text-lg md:text-xl max-w-2xl mx-auto">
        Showing {posts.length} {posts.length === 1 ? 'article' : 'articles'} in the #{tagName} collection.
      </p>
    </header>

    <div class="grid gap-12 max-w-3xl mx-auto">
      {posts.map((post) => (
        <article class="group relative flex flex-col items-start">
          <h2 class="text-2xl font-bold text-white mb-2 group-hover:text-zinc-400 transition-colors">
            <a href={`/blog/${post.id}/`}>
              <span class="absolute -inset-x-4 -inset-y-6 z-0 scale-95 bg-zinc-800/50 opacity-0 transition group-hover:scale-100 group-hover:opacity-100 sm:-inset-x-6 sm:rounded-2xl" />
              <span class="relative z-10">{post.data.title}</span>
            </a>
          </h2>
          <time class="relative z-10 order-first mb-3 flex items-center text-sm text-zinc-500 pl-3.5" datetime={post.data.pubDate.toISOString()}>
            <span class="absolute inset-y-0 left-0 flex items-center" aria-hidden="true">
              <span class="h-4 w-0.5 rounded-full bg-zinc-500" />
            </span>
            {formatDate(post.data.pubDate)}
          </time>
          <p class="relative z-10 text-sm text-zinc-400 leading-relaxed">
            {post.data.description}
          </p>
          <div class="relative z-10 mt-4 flex items-center text-sm font-medium text-white group-hover:translate-x-1 transition-transform">
            Read article
            <svg viewBox="0 0 16 16" fill="none" aria-hidden="true" class="ml-1 h-4 w-4 stroke-current">
              <path d="M6.75 5.75 9.25 8l-2.5 2.25" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </div>
        </article>
      ))}
    </div>
  </div>
</MainLayout>
