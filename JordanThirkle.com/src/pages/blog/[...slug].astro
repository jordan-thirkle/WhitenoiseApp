---
import { getCollection, render } from 'astro:content';
import MainLayout from '@/layouts/MainLayout.astro';
import TableOfContents from '@/components/astro/TableOfContents.astro';
import { SITE_CONFIG } from '@/config';

import { EngagementDock } from '@/components/react/EngagementDock';
import { Giscus } from '@/components/react/Giscus';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

const schema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": post.data.title,
  "image": [`${Astro.site}og/blog/${post.id}.png`],
  "datePublished": post.data.pubDate.toISOString(),
  "dateModified": post.data.pubDate.toISOString(),
  "author": [{
      "@type": "Person",
      "name": SITE_CONFIG.name,
      "url": Astro.site
    }],
  "description": post.data.description
};


---





<MainLayout 
  title={post.data.title} 
  description={post.data.description}
  image={`/og/blog/${post.id}.png`}
  articleDate={post.data.pubDate}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(schema)} />
  <header class="max-w-4xl mx-auto mb-16">
    <a href="/blog" class="text-sm font-bold text-zinc-500 hover:text-white transition-colors mb-8 inline-block uppercase tracking-widest">
      ← Back to articles
    </a>
    
    <div class="space-y-6">
      <div class="flex items-center gap-3 text-sm text-zinc-500 font-bold uppercase tracking-widest">
        <time datetime={post.data.pubDate.toISOString()}>
          {post.data.pubDate.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
        </time>
        <span>•</span>
        <span>{post.data.readTime}</span>
      </div>
      
      <h1 class="text-4xl md:text-7xl font-bold tracking-tighter text-white leading-[1.1]">
        {post.data.title}
      </h1>
      
      <p class="text-xl text-zinc-400 max-w-2xl leading-relaxed">
        {post.data.description}
      </p>

      <div class="flex flex-wrap gap-3 pt-4">
        {post.data.tags.map((tag) => (
          <a 
            href={`/blog/tags/${tag.toLowerCase()}`}
            class="text-[10px] font-bold uppercase tracking-widest text-zinc-400 bg-zinc-900 border border-zinc-800 px-3 py-1 rounded-full hover:border-zinc-600 hover:text-white transition-all"
          >
            {tag}
          </a>
        ))}
      </div>
    </div>

    {post.data.image && (
      <div class="mt-16 aspect-[21/9] rounded-3xl overflow-hidden border border-zinc-800 shadow-2xl bg-zinc-900">
        <img 
          src={post.data.image} 
          alt={post.data.title}
          class="w-full h-full object-cover object-center opacity-90"
        />
      </div>
    )}
  </header>

  <div class="flex flex-col lg:flex-row gap-12 relative">
    <TableOfContents headings={headings} />

    <article class="prose prose-zinc prose-invert max-w-3xl flex-grow">
      <Content />

      <!-- Giscus Comments Section -->
      <div id="comments" class="mt-24 pt-12 border-t border-zinc-900 not-prose">
        <div class="mb-8">
          <h2 class="text-2xl font-bold text-white">Discussions</h2>
          <p class="text-zinc-400 mt-2">Be the first to share your thoughts or ask a question.</p>
        </div>
        <Giscus client:visible />
      </div>
    </article>
  </div>

  <EngagementDock client:load title={post.data.title} url={Astro.url.toString()} path={Astro.url.pathname} initialLikes={post.data.likes} initialViews={post.data.views} />
</MainLayout>
