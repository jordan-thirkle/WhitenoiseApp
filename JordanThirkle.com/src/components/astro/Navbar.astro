---
const navItems = [
  { name: 'The Story', href: '/about' },
  { name: 'Projects', href: '/projects' },
  { name: 'Blog', href: '/blog' },
  { name: 'Dev Log', href: '/devlog' },
  { name: 'Uses', href: '/uses' },
];

const pathname = new URL(Astro.request.url).pathname;
const currentPath = pathname.replace(/\/$/, "");
---

<header class="fixed top-0 w-full z-40 bg-zinc-950/80 backdrop-blur-md border-b border-zinc-900">
  <nav class="container mx-auto px-6 max-w-[1440px] h-16 flex items-center justify-between">
    <a href="/" class="text-white font-bold tracking-tighter text-xl flex items-center gap-2 group" aria-label="Home">
      <div class="w-8 h-8 bg-white rounded-lg flex items-center justify-center text-zinc-950 transition-transform group-hover:scale-110">
        J
      </div>
      <span class="hidden sm:block">Jordan Thirkle</span>
    </a>

    <div class="flex items-center gap-4 md:gap-6">
      <button 
        id="search-trigger" aria-keyshortcuts="Control+K Meta+K"
        class="flex items-center gap-2 px-3 py-1.5 bg-zinc-900 border border-zinc-800 rounded-lg text-zinc-400 hover:text-white hover:border-zinc-700 transition-all text-sm group"
        aria-label="Open Search"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
        <span class="hidden xs:inline">Search</span>
        <kbd class="hidden sm:inline-flex items-center gap-1 px-1.5 py-0.5 bg-zinc-800 rounded border border-zinc-700 font-sans text-[10px] text-zinc-400 group-hover:text-zinc-300">
          <span id="modifier-key" class="text-xs">⌘</span>K
        </kbd>
      </button>

      <!-- Desktop Nav -->
      <ul class="hidden md:flex items-center gap-8">
        {navItems.map((item) => (
          <li>
            <a
              href={item.href}
              class={`text-sm font-medium transition-colors hover:text-white ${
                currentPath === item.href || (item.href !== "/" && currentPath.startsWith(item.href))
                  ? "text-zinc-100"
                  : "text-zinc-400"
              }`}
            >
              {item.name}
            </a>
          </li>
        ))}
        <div class="w-px h-4 bg-zinc-800 mx-2 self-center"></div>
        <li>
          <a
            href="/contact"
            class={`text-sm font-medium transition-colors hover:text-white flex items-center h-full ${
              currentPath === "/contact" || currentPath.startsWith("/contact/") ? "text-zinc-100" : "text-zinc-400"
            }`}
          >
            Contact
          </a>
        </li>
      </ul>

      <!-- Mobile Menu Toggle -->
      <button 
        id="mobile-menu-toggle"
        class="md:hidden p-2 text-zinc-400 hover:text-white transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white rounded-lg"
        aria-label="Toggle Menu"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>
    </div>
  </nav>

</header>

<!-- Mobile Drawer Overlay - Moved outside header context for absolute authority -->
<div 
  id="mobile-drawer" 
  class="fixed inset-0 z-[999] invisible md:hidden flex flex-col"
>
  <!-- Backdrop -->
  <div 
    id="mobile-backdrop"
    class="absolute inset-0 bg-zinc-950/95 backdrop-blur-3xl opacity-0 transition-opacity duration-500"
  ></div>
  
  <!-- Drawer Content -->
  <div 
    id="mobile-drawer-content"
    class="relative flex-1 flex flex-col items-center justify-center p-6 opacity-0 translate-y-4 transition-all duration-500 ease-out"
  >
    <button 
      id="mobile-menu-close" class="absolute top-6 right-6 p-4 text-zinc-400 hover:text-white transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white rounded-lg" aria-label="Close Menu"
      class="absolute top-6 right-6 p-4 text-zinc-400 hover:text-white transition-colors" 
      aria-label="Close Menu"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>

    <nav class="flex flex-col items-center gap-8 mb-16">
      {navItems.map((item, i) => (
        <a
          href={item.href}
          class={`group text-4xl md:text-5xl font-bold tracking-tighter transition-all hover:scale-105 ${
            currentPath === item.href || (item.href !== "/" && currentPath.startsWith(item.href))
              ? "text-white"
              : "text-zinc-500 hover:text-zinc-200"
          }`}
          style={`transition-delay: ${i * 50}ms`}
        >
          {item.name}
        </a>
      ))}
      <a
        href="/contact"
        class={`group text-4xl md:text-5xl font-bold tracking-tighter transition-all hover:scale-105 ${
          currentPath === "/contact" ? "text-white" : "text-zinc-500 hover:text-zinc-200"
        }`}
        style={`transition-delay: ${navItems.length * 50}ms`}
      >
        Contact
      </a>
    </nav>
    
    <div class="mt-8 flex flex-col items-center gap-8 opacity-0 translate-y-4 transition-all duration-700 delay-300" id="mobile-footer">
      <div class="flex items-center gap-12">
        <a href="https://x.com/jordan_thirkle" target="_blank" rel="noopener noreferrer" class="text-zinc-500 hover:text-white transition-colors p-2" aria-label="X (Twitter)">
          <svg viewBox="0 0 24 24" aria-hidden="true" class="w-6 h-6 fill-current"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"></path></svg>
        </a>
        <a href="https://github.com/jordan-thirkle" target="_blank" rel="noopener noreferrer" class="text-zinc-500 hover:text-white transition-colors p-2" aria-label="GitHub">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
        </a>
        <a href="https://linkedin.com/in/jordanthirkle" target="_blank" rel="noopener noreferrer" class="text-zinc-500 hover:text-white transition-colors p-2" aria-label="LinkedIn">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
        </a>
      </div>
      <div class="text-center space-y-2">
        <p class="text-[10px] font-bold uppercase tracking-[0.4em] text-zinc-500">Jordan Thirkle // © 2026</p>
        <p class="text-[8px] font-medium uppercase tracking-[0.6em] text-zinc-700">Strategic Architect</p>
      </div>
    </div>
  </div>
</div>

<script>
  import { isSearchOpen } from '@/store';
  
  const initNav = () => {
    const searchTrigger = document.getElementById('search-trigger');
    const modifierKey = document.getElementById('modifier-key');
    const mobileToggle = document.getElementById('mobile-menu-toggle');
    const mobileClose = document.getElementById('mobile-menu-close');
    const mobileDrawer = document.getElementById('mobile-drawer');
    const mobileBackdrop = document.getElementById('mobile-backdrop');
    const mobileContent = document.getElementById('mobile-drawer-content');
    
    // Detect OS
    if (modifierKey) {
      const isMac = navigator.userAgent.toUpperCase().indexOf('MAC') >= 0;
      modifierKey.textContent = isMac ? '⌘' : 'Ctrl+';
    }

    searchTrigger?.addEventListener('click', () => {
      isSearchOpen.set(true);
    });

    const openMenu = () => {
      mobileDrawer?.classList.remove('invisible');
      setTimeout(() => {
        mobileBackdrop?.classList.replace('opacity-0', 'opacity-100');
        mobileContent?.classList.replace('opacity-0', 'opacity-100');
        mobileContent?.classList.remove('translate-y-4');
        const footer = document.getElementById('mobile-footer');
        footer?.classList.replace('opacity-0', 'opacity-100');
        footer?.classList.remove('translate-y-4');
      }, 10);
      document.body.style.overflow = 'hidden';
    };

    const closeMenu = () => {
      mobileBackdrop?.classList.replace('opacity-100', 'opacity-0');
      mobileContent?.classList.replace('opacity-100', 'opacity-0');
      mobileContent?.classList.add('translate-y-4');
      const footer = document.getElementById('mobile-footer');
      footer?.classList.replace('opacity-100', 'opacity-0');
      footer?.classList.add('translate-y-4');
      setTimeout(() => {
        mobileDrawer?.classList.add('invisible');
      }, 500);
      document.body.style.overflow = '';
    };

    mobileToggle?.addEventListener('click', openMenu);
    mobileClose?.addEventListener('click', closeMenu);
    mobileBackdrop?.addEventListener('click', closeMenu);

    // Close on navigation
    const navLinks = mobileDrawer?.querySelectorAll('a');
    navLinks?.forEach(link => {
      link.addEventListener('click', closeMenu);
    });
  };

  // Run on initial load
  initNav();
  // Run on every navigation
  document.addEventListener('astro:page-load', initNav);
</script>
